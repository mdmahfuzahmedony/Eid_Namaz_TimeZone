generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

}

model User {
  id           String   @id @default(cuid())
  name         String
  phoneNumber  String   @unique
  password     String
  image        String?  
  
  // নতুন যোগ করা ফিল্ডসমূহ
  division     String?
  district     String?
  upazila      String?
  union        String?

  createdAt    DateTime @default(now())
  masjids      Masjid[]
}
model Masjid {
  id           String   @id @default(cuid())
  name         String
  type         String   
  imamName     String?
  mapLink      String?
  imageUrl     String?
  jamaat1      String?  
  jamaat2      String?
  
  // ✅ নতুন যোগ করা হলো
  isPublished  Boolean  @default(false) 
  
  approved     Boolean  @default(true) 
  createdAt    DateTime @default(now())

  // লোকেশন ডাটা (আগের মতোই থাকবে)
  divisionId   String
  districtId   String
  upazilaId    String   @default("")
  unionId      String   @default("")
  gram         String   @default("")
  divisionName String
  districtName String
  upazilaName  String   @default("")
  unionName    String   @default("")

  userId       String
  user         User     @relation(fields: [userId], references: [id])
}